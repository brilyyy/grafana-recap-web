{
  "name": "grafana-recap-web",
  "version": "3.0.0",
  "type": "module",
  "description": "Grafana Recap CMS Dashboard",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:push": "drizzle-kit push",
    "drizzle:studio": "drizzle-kit studio",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:schema": "tsx src/db/migrate.ts --schema-only",
    "db:migrate:procedures": "tsx src/db/migrate.ts --procedures-only",
    "db:migrate:seed": "tsx src/db/migrate.ts --seed-only",
    "db:seed-superadmin": "tsx src/db/seed-superadmin.ts",
    "db:migrate:fdw": "tsx src/db/migrate.ts --fdw-only",
    "db:setup": "npm run db:migrate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
