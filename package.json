{
  "name": "dashboard-grafana-nextjs",
  "version": "2.0.0",
  "description": "Dashboard Grafana - Migrated to Next.js",
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node node_modules/next/dist/bin/next lint",
    "type-check": "tsc --noEmit",
    "migration:generate": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; npx typeorm-ts-node-commonjs migration:generate -d typeorm.config.ts\"",
    "migration:run": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; npx typeorm-ts-node-commonjs migration:run -d typeorm.config.ts\"",
    "migration:revert": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; npx typeorm-ts-node-commonjs migration:revert -d typeorm.config.ts\"",
    "migration:show": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; npx typeorm-ts-node-commonjs migration:show -d typeorm.config.ts\"",
    "migration:mysql:generate": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; $env:DB_TYPE='mysql'; npx typeorm-ts-node-commonjs migration:generate -d typeorm.config.ts\"",
    "migration:mysql:run": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; $env:DB_TYPE='mysql'; npx typeorm-ts-node-commonjs migration:run -d typeorm.config.ts\"",
    "migration:mysql:revert": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; $env:DB_TYPE='mysql'; npx typeorm-ts-node-commonjs migration:revert -d typeorm.config.ts\"",
    "migration:mysql:show": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; $env:DB_TYPE='mysql'; npx typeorm-ts-node-commonjs migration:show -d typeorm.config.ts\"",
    "migration:postgres:generate": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; $env:DB_TYPE='postgresql'; npx typeorm-ts-node-commonjs migration:generate -d typeorm.config.postgresql.ts\"",
    "migration:postgres:run": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; $env:DB_TYPE='postgresql'; npx typeorm-ts-node-commonjs migration:run -d typeorm.config.postgresql.ts\"",
    "migration:postgres:revert": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; $env:DB_TYPE='postgresql'; npx typeorm-ts-node-commonjs migration:revert -d typeorm.config.postgresql.ts\"",
    "migration:postgres:show": "powershell -Command \"$env:TS_NODE_PROJECT='tsconfig.typeorm.json'; $env:DB_TYPE='postgresql'; npx typeorm-ts-node-commonjs migration:show -d typeorm.config.postgresql.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.2.3",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
}
