  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^20.17.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.9",
