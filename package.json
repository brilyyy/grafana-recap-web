{
  "name": "grafana-recap-web",
  "version": "3.0.0",
  "type": "module",
  "description": "Grafana Recap CMS Dashboard",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "type-check": "tsc --noEmit",
    "drizzle:postgres:generate": "cross-env DB_TYPE=postgresql drizzle-kit generate",
    "drizzle:postgres:migrate": "cross-env DB_TYPE=postgresql drizzle-kit migrate",
    "drizzle:postgres:push": "cross-env DB_TYPE=postgresql drizzle-kit push",
    "drizzle:postgres:studio": "cross-env DB_TYPE=postgresql drizzle-kit studio",
    "db:migrate": "npx tsx src/db/migrate.ts",
    "db:migrate:schema": "npx tsx src/db/migrate.ts --schema-only",
    "db:migrate:procedures": "npx tsx src/db/migrate.ts --procedures-only",
    "db:migrate:cron": "npx tsx src/db/migrate.ts --cron-only",
    "db:migrate:seed": "npx tsx src/db/migrate.ts --seed-only",
    "db:migrate:fdw": "npx tsx src/db/migrate.ts --fdw-only",
    "db:setup": "npm run db:migrate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "@vitejs/plugin-react": "^6.0.2",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.4.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.575.0",
    "node-cron": "^4.2.1",
    "pg": "^8.13.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.9",
    "postcss": "^8.4.47",
    "shadcn": "^4.11.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
