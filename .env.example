# Database (required)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=platform_db

# FDW: grant USAGE on foreign servers to this user (optional)
# DB_USER_TARGET=app_user

# Cron / scheduler (optional)
BALE_PROCESSING_SCHEDULE=1 0 * * *
BALE_BISNIS_PROCESSING_SCHEDULE=1 0 * * *
OLOB_PROCESSING_SCHEDULE=1 0 * * *
EDC_AGEN_PROCESSING_SCHEDULE=1 0 * * *
EDC_MERCHANT_PROCESSING_SCHEDULE=1 0 * * *
EDC_MERCHANT_ANCOL_PROCESSING_SCHEDULE=1 0 * * *
USE_APP_LEVEL_SCHEDULER=false
TARGET_DATABASES=platform_db,platform_db_dev

# Housekeeping cron – pg_cron schedule for raw table retention jobs
# Format: standard cron expression (minute hour day month weekday)
# Default: every day at 02:00 AM
HOUSEKEEPING_SCHEDULE=0 2 * * *

# Seed superadmin (optional – comma-separated for multiple)
DEFAULT_SU_USERNAME=admin
DEFAULT_SU_PASSWORD=your-secure-password
DEFAULT_SU_EMAIL=admin@example.com
