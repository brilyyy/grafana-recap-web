@startuml Upload Success Rate Flow
actor User
participant "AddSuccessRateCard" as Frontend
participant "API /upload-success-rate" as API
participant "MySQL Database" as DB

User -> Frontend: Select application & upload file
Frontend -> Frontend: Validate file extension & columns
Frontend -> Frontend: Parse file (Excel/CSV)

Frontend -> API: POST /api/upload-success-rate (FormData)
API -> API: Parse FormData
API -> API: Parse file & validate rows

alt Skipped rows found
    API -> Frontend: Return error dengan skippedRows
    Frontend -> User: Show ErrorPopup
else All rows valid
    API -> DB: Verify application exists
    DB -> API: Application data
    
    API -> DB: BEGIN TRANSACTION
    
    loop For each transaction entry
        API -> API: Parse tanggal_transaksi (DD/MM/YYYY atau YYYY-MM-DD)
        API -> API: Extract bulan & tahun
        API -> API: Validate jenis_transaksi (required)
        
        alt Status = 'sukses'
            API -> API: Set RC = '00', RC Description = 'Success'
        end
        
        alt RC exists
            API -> DB: Lookup error_type dari dictionary\n(exact match: jenis_transaksi + RC)
            alt Found in dictionary
                DB -> API: error_type
                API -> API: Assign error_type dari dictionary
            else Not found
                API -> DB: Lookup by RC only
                alt Found
                    DB -> API: error_type
                    API -> API: Assign error_type
                else Not found
                    API -> DB: INSERT INTO unmapped_rc
                    API -> API: error_type = NULL
                end
            end
        else RC NULL
            alt Status = 'sukses'
                API -> API: error_type = 'Sukses'
            else Status != 'sukses'
                API -> API: error_type = NULL (masuk ke No RC Transaction)
            end
        end
        
        API -> DB: INSERT INTO app_success_rate
    end
    
    alt Error occurred
        API -> DB: ROLLBACK TRANSACTION
        API -> Frontend: Return error
    else Success
        API -> DB: COMMIT TRANSACTION
        DB -> API: Success
        API -> Frontend: Return success dengan entriesProcessed
        Frontend -> Frontend: Reset form
        Frontend -> Frontend: Dispatch 'successRateUploaded' event
        Frontend -> User: Show success message
    end
end

@enduml
