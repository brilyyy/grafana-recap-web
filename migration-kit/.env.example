# Database (required)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=platform_db

# For PostgreSQL use:
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=platform_db

# Cron / scheduler (optional)
BALE_PROCESSING_SCHEDULE=1 0 * * *
BALE_BISNIS_PROCESSING_SCHEDULE=1 0 * * *
USE_APP_LEVEL_SCHEDULER=false
TARGET_DATABASES=platform_db,platform_db_dev

# Seed superadmin (optional – comma-separated for multiple)
DEFAULT_SU_USERNAME=admin
DEFAULT_SU_PASSWORD=your-secure-password
DEFAULT_SU_EMAIL=admin@example.com
